# Laser reproduce configs: paths are machine-specific (dev-box hard-coded).
# Only canonical examples + alignment-contract configs are tracked;
# copy + edit locally for your own runs.
/examples/laser/configs/*.toml
!/examples/laser/configs/gist.toml
